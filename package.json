{
    "name": "@supercat1337/store2",
    "version": "2.0.0",
    "description": "A lightweight, efficient, and easy-to-use reactive state management system for JavaScript applications.",
    "author": "Albert Bazaleev",
    "license": "MIT",
    "type": "module",
    "moduleResolution": "nodenext",
    "scripts": {
        "test": "c8 ava",
        "test_custom": "c8 ava ./tests/api/api.test.js:744-786",
        "clean": "shx rm -rf ./dist && shx mkdir ./dist",
        "build_esm": "rollup ./src/index.js --file ./dist/store2.esm.js --format es",
        "gen_types": "npx tsc --project my.tsconfig.types.json",
        "bundle_types": "node scripts/bundle-types.js",
        "build": "npm run clean && npm run build_esm && npm run gen_types && npm run bundle_types && shx rm -rf dist/types-temp",
        "lint": "eslint src/ tests/ scripts/",
        "lint_fix": "npm run lint -- --fix",
        "docs": "typedoc --tsconfig \"my.tsconfig.docs.json\" --options \"typedoc.json\"",
        "docs-md": "typedoc --tsconfig \"my.tsconfig.docs.json\" --options \"typedoc-md.json\""
    },
    "devDependencies": {
        "@eslint/js": "^9.18.0",
        "@rollup/plugin-node-resolve": "^15.3.0",
        "@types/node": "^20.19.43",
        "ava": "^8.0.1",
        "c8": "^9.1.0",
        "eslint": "^9.18.0",
        "eslint-plugin-eqeqeq-fix": "^1.0.3",
        "eslint-plugin-jsdoc": "^63.0.2",
        "globals": "^15.14.0",
        "rollup": "^4.60.1",
        "shx": "^0.4.0",
        "typedoc": "^0.25.13",
        "typedoc-plugin-markdown": "^3.17.1",
        "typedoc-plugin-missing-exports": "^2.2.0"
    },
    "keywords": [
        "reactive",
        "state",
        "state-management",
        "reactive-state",
        "scalable state management"
    ],
    "publishConfig": {
        "registry": "https://registry.npmjs.org"
    },
    "homepage": "https://github.com/supercat1337/store2",
    "site": "https://github.com/supercat1337/store2",
    "dependencies": {
        "@supercat1337/dictionary": "^1.0.0",
        "@supercat1337/event-emitter": "^2.0.1",
        "@supercat1337/event-emitter-ext": "^1.0.8"
    },
    "ava": {
        "files": [
            "tests/**/*.test.js"
        ],
        "nodeArguments": [
            "--experimental-vm-modules"
        ],
        "extensions": [
            "js"
        ]
    },
    "files": [
        "dist/",
        "README.md",
        "AI_DOCS.md",
        "LICENSE"
    ]
}
